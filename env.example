# Copy this to .env and fill in values

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+psycopg://neondb_owner:password@ep-xxx-pooler.neon.tech/neondb?sslmode=require
DATABASE_URL_SYNC=postgresql+psycopg://neondb_owner:password@ep-xxx-pooler.neon.tech/neondb?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM — OpenRouter
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_FALLBACK_MODEL=anthropic/claude-haiku-4.5
LLM_DAILY_BUDGET_USD=1.0

# Neon Auth — backend JWT verification
# URL from Neon dashboard → Auth → Settings
NEON_AUTH_URL=https://ep-super-paper-an55azbc.neonauth.c-6.us-east-1.aws.neon.tech/neondb/auth
ADMIN_ALLOWED_EMAIL=luisjmolina29@gmail.com

# Sentry
SENTRY_DSN=https://...@sentry.io/...
ENVIRONMENT=development

# App
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

